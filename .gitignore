# ==========================================
# Secrets / local config
# ==========================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.crt

# ==========================================
# Python environments / caches
# ==========================================
.venv/
venv/
env/
ENV/
__pycache__/
*/__pycache__/
*.py[cod]
*$py.class
.pycache_tmp/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ==========================================
# Build / packaging
# ==========================================
build/
dist/
site/
*.egg
*.egg-info/
.installed.cfg
pip-wheel-metadata/

# ==========================================
# Logs / runtime temp files
# ==========================================
*.log
logs/
log/
tmp/
temp/
*.pid
*.out
*.err

# ==========================================
# Local data / generated artifacts
# Keep source json/csv trackable; ignore only generated storage
# ==========================================
data/
cache/
uploads/
downloads/
artifacts/
checkpoints/
*.sqlite3
*.db

# ==========================================
# IDE / editor / OS files
# ==========================================
.idea/
.vscode/
!.vscode/extensions.json
Thumbs.db
desktop.ini
.DS_Store

# ==========================================
# Frontend / misc
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
